{
  "name": "lema-markdown-monorepo",
  "version": "0.20.0-dev",
  "description": "Lema Markdown monorepo root",
  "private": true,
  "homepage": "https://github.com/gastonlema/lema-markdown",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "postinstall": "tsx scripts/postinstall.ts",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "minify-locales": "tsx scripts/minify-locales.ts",
    "rebuild-native": "pnpm --filter lema-markdown rebuild-native",
    "start": "pnpm --filter lema-markdown start",
    "dev": "pnpm --filter lema-markdown dev",
    "build": "pnpm --filter lema-markdown build",
    "build:unpack": "pnpm --filter lema-markdown build:unpack",
    "build:win": "pnpm --filter lema-markdown build:win",
    "build:win:x64": "pnpm --filter lema-markdown build:win:x64",
    "build:win:arm64": "pnpm --filter lema-markdown build:win:arm64",
    "build:mac": "pnpm --filter lema-markdown build:mac",
    "build:mac:x64": "pnpm --filter lema-markdown build:mac:x64",
    "build:mac:arm64": "pnpm --filter lema-markdown build:mac:arm64",
    "build:linux": "pnpm --filter lema-markdown build:linux",
    "perf:inspect": "pnpm --filter lema-markdown perf:inspect",
    "perf:inspect-brk": "pnpm --filter lema-markdown perf:inspect-brk",
    "test": "pnpm --filter lema-markdown test",
    "test:unit": "pnpm --filter lema-markdown test:unit",
    "test:e2e": "pnpm --filter lema-markdown test:e2e",
    "typecheck": "pnpm --filter lema-markdown typecheck",
    "typecheck:watch": "pnpm --filter lema-markdown typecheck:watch",
    "check": "pnpm lint && pnpm typecheck",
    "gen-third-party": "tsx scripts/generateThirdPartyLicense.ts",
    "validate-licenses": "tsx scripts/validateLicenses.ts"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "electron": "^42.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-vue": "^10.9.1",
    "license-checker": "^25.0.1",
    "neostandard": "^0.13.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.59.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
